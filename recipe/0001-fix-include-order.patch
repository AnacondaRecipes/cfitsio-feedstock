Date: Wed, 16 Jul 2025 10:09:48 +0200
Subject: [PATCH] fix include order

Include fitsio2.h as last one, so that Windows SDK doesn't conflict with TBYTE definition of cfitsio
---
 drvrmem.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/drvrmem.c b/drvrmem.c
index 3696daf..85fde80 100644
--- a/drvrmem.c
+++ b/drvrmem.c
@@ -7,12 +7,13 @@
 #include <string.h>
 #include <stdlib.h>
 #include <stddef.h>  /* apparently needed to define size_t */
-#include "fitsio2.h"
 
 #if HAVE_BZIP2
 #include "bzlib.h"
 #endif
 
+#include "fitsio2.h"
+
 /* prototype for .Z file uncompression function in zuncompress.c */
 int zuncompress2mem(char *filename, 
              FILE *diskfile, 
